PORT=3001
NODE_ENV=development
ADMIN_USERNAME=defina_usuario
ADMIN_PASSWORD=defina_senha_segura
SMTP_HOST=smtp.seuprovedor.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=contato@seuprojeto.com
SMTP_PASS=senha-ou-app-password
CONTACT_EMAIL=destinatario@seuprojeto.com
# Docker local (docker-compose.yml): compose injeta SMTP_USE_ETHEREAL=true — formulário funciona sem preencher SMTP.
# Produção: preencha SMTP_* (Gmail: senha de app) ou configure SMTP no painel admin; senha pode ficar só no .env (merge com DB).
# SMTP_USE_ETHEREAL=true
ASSET_BASE_URL=http://localhost:3001
VITE_API_URL=http://localhost:3001
DATABASE_URL=postgresql://portfolio:portfolio@portfolio-db:5432/portfolio?schema=public
JWT_SECRET=troque_por_um_segredo_seguro
PORTFOLIO_DEFAULT_EMAIL=seu.email@dominio.com
PORTFOLIO_DEFAULT_PASSWORD=senha_portfolio
